{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd Backend && dotnet publish -c Release -o out"
  },
  "deploy": {
    "startCommand": "cd Backend/out && dotnet CoupleChat.dll",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "variables": {
    "RAILPACK_DOTNET_VERSION": "10.0"
  }
}
