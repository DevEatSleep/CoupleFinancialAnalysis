@using Frontend.Services
@using Frontend.Models
@inject ChatState State
@inject ApiClient Api
@inject LocalizationService Loc
@implements IDisposable

<table class="expenses-table">
    <thead>
        <tr>
            <th>@Loc.T("dashboard.expenseLabel")</th>
            <th>@Loc.T("dashboard.amount")</th>
            <th>@Loc.T("dashboard.paidBy")</th>
            <th>@Loc.T("dashboard.actions")</th>
        </tr>
    </thead>
    <tbody>
        @if (State.Expenses.Count == 0)
        {
            <tr><td colspan="4" class="empty-state">@Loc.T("dashboard.noExpenses")</td></tr>
        }
        else
        {
            @foreach (var expense in State.Expenses)
            {
                <tr>
                    <td class="editable" @onclick="() => StartEdit(expense.Id, FieldLabel, expense.Label)">
                        @if (IsEditing(expense.Id, FieldLabel))
                        {
                            <input type="text" @bind="EditValue" @onblur="SaveEdit" @onkeydown="HandleEditKey" autofocus style="width:100%;" />
                        }
                        else
                        {
                            @expense.Label
                        }
                    </td>
                    <td class="editable" @onclick="() => StartEdit(expense.Id, FieldAmount, expense.Amount.ToString())">
                        @if (IsEditing(expense.Id, FieldAmount))
                        {
                            <input type="number" step="0.01" @bind="EditValue" @onblur="SaveEdit" @onkeydown="HandleEditKey" autofocus style="width:100%;" />
                        }
                        else
                        {
                            @expense.Amount
                        }
                    </td>
                    <td class="editable" @onclick="() => StartEdit(expense.Id, FieldPaidBy, expense.PaidBy)">
                        @if (IsEditing(expense.Id, FieldPaidBy))
                        {
                            <input type="text" @bind="EditValue" @onblur="SaveEdit" @onkeydown="HandleEditKey" autofocus style="width:100%;" />
                        }
                        else
                        {
                            @expense.PaidBy
                        }
                    </td>
                    <td>
                        <button class="delete-btn" @onclick="() => DeleteExpense(expense.Id)">🗑️</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private const string FieldLabel = "label";
    private const string FieldAmount = "amount";
    private const string FieldPaidBy = "paidBy";

    private int? _editingId;
    private string? _editingField;
    private string EditValue { get; set; } = "";

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
        Loc.OnLanguageChanged += () => InvokeAsync(StateHasChanged);
    }

    private bool IsEditing(int id, string field) => _editingId == id && _editingField == field;

    private void StartEdit(int id, string field, string currentValue)
    {
        _editingId = id;
        _editingField = field;
        EditValue = currentValue;
    }

    private async Task SaveEdit()
    {
        if (_editingId is not null && _editingField is not null && !string.IsNullOrWhiteSpace(EditValue))
        {
            var expense = State.Expenses.Find(e => e.Id == _editingId);
            if (expense is not null)
            {
                var updated = new Expense
                {
                    Id = expense.Id,
                    Label = _editingField == "label" ? EditValue : expense.Label,
                    Amount = _editingField == "amount" && decimal.TryParse(EditValue, out var amt) ? amt : expense.Amount,
                    PaidBy = _editingField == "paidBy" ? EditValue : expense.PaidBy
                };
                await Api.UpdateExpenseAsync(expense.Id, updated);
            }
        }
        _editingId = null;
        _editingField = null;
    }

    private async Task HandleEditKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveEdit();
        if (e.Key == "Escape") { _editingId = null; _editingField = null; }
    }

    private async Task DeleteExpense(int id)
    {
        await Api.DeleteExpenseAsync(id);
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
