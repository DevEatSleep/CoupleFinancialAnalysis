@using BlazorFrontend.Services
@inject LocalizationService Loc

<div id="language-selector" style="display: flex; gap: 2px;">
    <button class="lang-btn @(Loc.CurrentLanguage == "en" ? "active" : "")"
            @onclick='() => ChangeLanguage("en")' title="English">🇬🇧</button>
    <button class="lang-btn @(Loc.CurrentLanguage == "fr" ? "active" : "")"
            @onclick='() => ChangeLanguage("fr")' title="Français">🇫🇷</button>
    <button class="lang-btn @(Loc.CurrentLanguage == "es" ? "active" : "")"
            @onclick='() => ChangeLanguage("es")' title="Español">🇪🇸</button>
</div>

@code {
    private void ChangeLanguage(string lang)
    {
        Loc.SetLanguage(lang);
    }
}
